# ── Copy this file to .env and fill in your values ──────────────────────────
# Never commit .env to GitHub!

# Groq (get from console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SerpAPI (get from serpapi.com)
SERPAPI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion (get from notion.so/my-integrations)
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_NOTES_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # Page ID from your Notes page URL
NOTION_TASKS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx     # Database ID from your Tasks DB URL
NOTION_CALENDAR_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # Database ID from your Calendar DB URL

# Gmail (enable 2FA first, then generate App Password at myaccount.google.com/apppasswords)
GMAIL_ADDRESS=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
