# ── Copy this file to .env and fill in your values ──────────────────────────
# Never commit .env to GitHub!

# ── Groq (console.groq.com) ──────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Telegram (get from @BotFather) ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your personal Telegram chat ID — forward any message to @userinfobot to find it
MY_TELEGRAM_CHAT_ID=123456789

# ── SerpAPI (serpapi.com) — used by the agent's web_search tool ──────────────
SERPAPI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── NewsAPI (newsapi.org) — used by the daily news emailer (100 req/day free) ─
NEWSAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Notion (notion.so/my-integrations) ──────────────────────────────────────
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_NOTES_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_TASKS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_CALENDAR_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Gmail ─────────────────────────────────────────────────────────────────────
# Enable 2FA first, then generate App Password at:
# myaccount.google.com/apppasswords
GMAIL_ADDRESS=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
